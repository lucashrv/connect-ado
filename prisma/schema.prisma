generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  INSTITUTION
  ADOPTER
  CHILD
}

model User {
  id                 String       @id @default(uuid())
  name               String
  email              String       @unique
  password           String
  role               Role
  is_active          Boolean      @default(true)
  updatedAt          DateTime     @updatedAt
  createdAt          DateTime     @default(now())
  // Relations
  institutionProfile Institution?
  adopterProfile     Adopter?
  child              Child?
}

model Institution {
  id                        String    @id @default(uuid())
  name                      String
  cnpj                      String    @unique
  phone                     String    @unique
  full_address              String
  legal_representative_name String
  foundation_date           DateTime  @db.Date
  license_number            String
  website_url               String
  updatedAt                 DateTime  @updatedAt
  createdAt                 DateTime  @default(now())
  // User
  user_id                   String    @unique
  user                      User      @relation(fields: [user_id], references: [id])
  // Relations
  adopterProfile            Adopter[]
  childProfile              Child[]
}

model Adopter {
  id             String       @id @default(uuid())
  full_name      String
  governmentId   String       @unique
  // User
  user_id        String       @unique
  user           User         @relation(fields: [user_id], references: [id])
  // Institution
  institution_id String?
  institution    Institution? @relation(fields: [institution_id], references: [id])
  // Relations
  childProfile   Child[]
}

model Child {
  id              String      @id @default(uuid())
  full_name       String
  nickname        String?
  age             String
  // Data by institution
  health_record   String?     @db.Text
  education_level String?
  // User
  user_id         String      @unique
  user            User        @relation(fields: [user_id], references: [id])
  // Institution
  institutionId   String
  institution     Institution @relation(fields: [institutionId], references: [id])
  // Adopter
  adopter_id      String?
  adopter         Adopter?    @relation(fields: [adopter_id], references: [id])
}
