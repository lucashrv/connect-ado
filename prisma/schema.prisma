generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  password           String
  role               Role
  is_active          Boolean      @default(true)
  updatedAt          DateTime     @updatedAt
  createdAt          DateTime     @default(now())
  adopterProfile     Adopter?
  child              Child?
  institutionProfile Institution?
}

model Institution {
  id                        String    @id @default(uuid())
  name                      String
  cnpj                      String    @unique
  phone                     String    @unique
  full_address              String
  legal_representative_name String
  foundation_date           DateTime  @db.Date
  license_number            String
  website_url               String
  updatedAt                 DateTime  @updatedAt
  createdAt                 DateTime  @default(now())
  user_id                   String    @unique
  adopterProfile            Adopter[]
  childProfile              Child[]
  user                      User      @relation(fields: [user_id], references: [id])
}

model Adopter {
  id             String        @id @default(uuid())
  full_name      String
  cpf            String        @unique
  phone          String
  birth_date     DateTime      @db.Date
  gender         Gender
  address        String
  occupation     String
  updatedAt      DateTime      @updatedAt
  createdAt      DateTime      @default(now())
  user_id        String        @unique
  institution_id String?
  institution    Institution?  @relation(fields: [institution_id], references: [id])
  user           User          @relation(fields: [user_id], references: [id])
  childProfile   Child[]
  adopterPosts   AdopterPost[]
}

model Child {
  id                  String               @id @default(uuid())
  full_name           String
  nickname            String?
  birth_date          DateTime             @db.Date
  cpf                 String               @unique
  gender              Gender
  updatedAt           DateTime             @updatedAt
  createdAt           DateTime             @default(now())
  health_record       String?
  education_level     String?
  user_id             String               @unique
  institutionId       String
  adopter_id          String?
  adopter             Adopter?             @relation(fields: [adopter_id], references: [id])
  institution         Institution          @relation(fields: [institutionId], references: [id])
  user                User                 @relation(fields: [user_id], references: [id])
  childPersonalManual ChildPersonalManual?
}

model ChildPersonalManual {
  id                String  @id @default(uuid())
  daily_routine     String?
  favorite_food     String?
  favorite_music    String?
  favorite_activity String?
  hobbies           String?
  study_habits      String?
  fears             String?
  notes             String?
  child_id          String  @unique
  child             Child   @relation(fields: [child_id], references: [id])
}

enum Role {
  INSTITUTION
  ADOPTER
  CHILD
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model AdopterPost {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  photo_url String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isLiked   Boolean  @default(false)

  adopter_id String
  adopter    Adopter @relation(fields: [adopter_id], references: [id], onDelete: Cascade)
}
