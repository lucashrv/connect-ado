generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  INSTITUTION
  ADOPTER
  CHILD
}

model User {
  id                 String       @id @default(uuid())
  name               String
  email              String       @unique
  password           String
  role               Role
  is_active          Boolean      @default(true)
  updatedAt          DateTime     @updatedAt
  createdAt          DateTime     @default(now())
  // Relations
  institutionProfile Institution?
  adopterProfile     Adopter?
}

model Institution {
  id                        String    @id @default(uuid())
  name                      String
  cnpj                      String    @unique
  phone                     String    @unique
  full_address              String
  legal_representative_name String
  foundation_date           DateTime  @db.Date
  license_number            String
  website_url               String
  updatedAt                 DateTime  @updatedAt
  createdAt                 DateTime  @default(now())
  // User
  user_id                   String    @unique
  user                      User      @relation(fields: [user_id], references: [id])
  // Relations
  adopterProfile            Adopter[]
}

model Adopter {
  id             String       @id @default(uuid())
  full_name      String
  governmentId   String       @unique
  // User
  user_id        String       @unique
  user           User         @relation(fields: [user_id], references: [id])
  // Institution
  institution_id String?
  institution    Institution? @relation(fields: [institution_id], references: [id])
}
